.room-info-header {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.date-label {
  font-size: 24rpx;
  color: #999;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-select-item {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.tag-select-item.selected {
  background: #FDE8E8;
  color: #E74C3C;
  border-color: #E74C3C;
}

.selected-count {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #E74C3C;
}

.cooking-input {
  border-color: #F0C060;
  background: #FFFDF5;
}
