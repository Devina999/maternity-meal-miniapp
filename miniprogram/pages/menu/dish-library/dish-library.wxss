.dish-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
}

.dish-ingredients {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.dish-ingredients text {
  margin-right: 12rpx;
}

.dish-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 30rpx;
}

.action-link {
  font-size: 24rpx;
  color: #4A90D9;
}

.action-link.danger {
  color: #E74C3C;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
  max-height: 50vh;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 40rpx;
  border-top: 1rpx solid #eee;
}

.modal-footer button {
  flex: 1;
}

.ingredient-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ing-select {
  min-width: 180rpx;
  padding: 14rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.amount-input {
  width: 100rpx;
  padding: 14rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
}

.remove-btn {
  color: #E74C3C;
  font-size: 28rpx;
  padding: 10rpx;
}

.add-ing-btn {
  color: #4A90D9;
  font-size: 24rpx;
  padding: 10rpx 0;
}
