<view class="container">
  <!-- 菜品列表 -->
  <view class="card" wx:for="{{dishes}}" wx:key="_id">
    <view class="dish-header">
      <view class="dish-name">{{item.name}}</view>
      <view class="tag tag-blue">{{item.category}}</view>
    </view>
    <view class="dish-ingredients" wx:if="{{item.ingredients.length > 0}}">
      食材：
      <text wx:for="{{item.ingredients}}" wx:key="ingredient_id" wx:for-item="ing">
        {{getIngredientName(ing.ingredient_id)}} {{ing.amount}}
      </text>
    </view>
    <view class="dish-actions" wx:if="{{canEdit}}">
      <text class="action-link" data-id="{{item._id}}" bindtap="onEditDish">编辑</text>
      <text class="action-link danger" data-id="{{item._id}}" bindtap="onDeleteDish">删除</text>
    </view>
  </view>

  <button class="btn-primary" bindtap="onShowForm" wx:if="{{canEdit}}">+ 添加菜品</button>

  <!-- 菜品编辑表单弹层 -->
  <view class="modal-mask" wx:if="{{showForm}}" bindtap="onCancel">
    <view class="modal-content" catchtap="noop">
      <view class="modal-title">{{editId ? '编辑菜品' : '添加菜品'}}</view>
      <scroll-view scroll-y class="modal-body">
        <view class="form-group">
          <view class="form-label">菜品名称</view>
          <input class="form-input" value="{{form.name}}" bindinput="onNameInput" placeholder="如：清蒸鲈鱼"/>
        </view>
        <view class="form-group">
          <view class="form-label">分类</view>
          <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
            <view class="form-input">{{form.category}}</view>
          </picker>
        </view>
        <view class="form-group">
          <view class="form-label">绑定食材</view>
          <view class="ingredient-row" wx:for="{{form.ingredientSelections}}" wx:key="index">
            <picker mode="selector" range="{{ingredients}}" range-key="name" data-index="{{index}}" data-field="id" bindchange="onIngredientChange">
              <view class="ing-select">{{getIngredientName(item.ingredient_id) || '选择食材'}}</view>
            </picker>
            <input class="amount-input" type="number" value="{{item.amount}}" data-index="{{index}}" data-field="amount" bindinput="onIngredientChange" placeholder="用量"/>
            <view class="remove-btn" data-index="{{index}}" bindtap="onRemoveIngredient">✕</view>
          </view>
          <view class="add-ing-btn" bindtap="onAddIngredient">+ 添加食材</view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="btn-outline" bindtap="onCancel">取消</button>
        <button class="btn-primary" bindtap="onSubmit">保存</button>
      </view>
    </view>
  </view>
</view>
