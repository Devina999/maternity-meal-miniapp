.ing-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.ing-name {
  font-size: 30rpx;
  font-weight: bold;
}

.stock-bar {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.stock-fill {
  height: 100%;
  background: #4A90D9;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.stock-fill.low {
  background: #E74C3C;
}

.stock-text {
  font-size: 24rpx;
  color: #666;
}

.alert-text {
  color: #E74C3C;
}

.ing-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 30rpx;
}

.action-link {
  font-size: 24rpx;
  color: #4A90D9;
}

.action-link.danger { color: #E74C3C; }
