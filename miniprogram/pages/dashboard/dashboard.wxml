<view class="dashboard">
  <!-- 顶部欢迎区 -->
  <view class="welcome-bar">
    <view class="welcome-info">
      <view class="welcome-text">你好，{{isSimulating ? simulatedRoleName : realRoleName}}</view>
      <view class="welcome-date">今天 {{today}} · 明天 {{tomorrow}}</view>
    </view>
    <view class="logout-btn" bindtap="handleLogout">退出</view>
  </view>

  <!-- 角色模拟提示条 -->
  <view class="role-sim-bar" wx:if="{{isSimulating}}">
    <view class="sim-hint">
      <text class="sim-icon">👁️</text>
      <text>正在以"{{simulatedRoleName}}"视角查看</text>
    </view>
    <view class="restore-btn" bindtap="onRestoreRole">还原身份</view>
  </view>

  <!-- 角色切换器（仅超管可见） -->
  <view class="role-switcher" wx:if="{{isSuperAdmin && !isSimulating}}">
    <view class="switcher-label">🔍 模拟角色视角</view>
    <picker mode="selector" range="{{simulateRoles}}" range-key="label" value="{{simulateRoleIndex}}" bindchange="onSimulateRoleChange">
      <view class="switcher-picker">{{simulateRoles[0].label}} ▾</view>
    </picker>
  </view>

  <!-- 功能入口分组 -->
  <block wx:for="{{menuGroups}}" wx:key="title">
    <view class="menu-group">
      <view class="group-title">
        <text class="group-icon">{{item.icon}}</text>
        <text>{{item.title}}</text>
      </view>
      <view class="menu-grid">
        <view
          class="menu-card"
          wx:for="{{item.items}}"
          wx:for-item="menu"
          wx:key="name"
          data-url="{{menu.url}}"
          bindtap="navigateTo"
        >
          <view class="menu-name">{{menu.name}}</view>
          <view class="menu-desc">{{menu.desc}}</view>
          <view class="menu-arrow">→</view>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{menuGroups.length === 0}}">
    <view class="empty-text">暂无可用功能，请联系管理员</view>
  </view>
</view>
