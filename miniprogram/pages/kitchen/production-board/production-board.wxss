.pb-container { padding: 20rpx; padding-bottom: 40rpx; }

.pb-date { text-align: center; font-size: 26rpx; color: #bbb; margin-bottom: 12rpx; }

.pb-tabs { display: flex; gap: 8rpx; margin-bottom: 16rpx; }
.pb-tab {
  flex:1; text-align:center; padding: 14rpx 0; background: #fff;
  border-radius: 25rpx; font-size: 26rpx; color: #999;
}
.pb-tab.active { background: #E8B4B8; color: #fff; font-weight: bold; }

.pb-stats { display: flex; gap: 10rpx; margin-bottom: 20rpx; }
.pb-stat {
  flex:1; text-align:center; background: #fff; border-radius: 14rpx;
  padding: 14rpx 0; font-size: 22rpx; color: #bbb;
}
.pb-stat-num { display: block; font-size: 34rpx; font-weight: bold; color: #E8B4B8; margin-bottom: 4rpx; }

/* ===== 分区标题 ===== */
.section { margin-bottom: 24rpx; }
.section-title {
  font-size: 28rpx; font-weight: bold; color: #555;
  padding: 12rpx 0; margin-bottom: 12rpx;
}

/* ===== 菜品汇总表格 ===== */
.dish-summary-table {
  background: #fff; border-radius: 16rpx; overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(255,107,157,0.06);
}

.table-header {
  display: flex; background: #F9F5F2; border-bottom: 2rpx solid #EED;
  padding: 18rpx 12rpx; font-size: 22rpx; font-weight: bold; color: #888;
}
.table-row {
  display: flex; padding: 16rpx 12rpx; border-bottom: 1rpx solid #F9F5F2;
  align-items: center; font-size: 24rpx;
}
.table-row:last-child { border-bottom: none; }

.th-dish, .td-dish { flex: 0 0 160rpx; padding: 0 4rpx; }
.th-portion, .td-portion { flex: 0 0 100rpx; text-align: center; padding: 0 4rpx; }
.th-excluded, .td-excluded { flex: 0 0 150rpx; padding: 0 4rpx; }
.th-reason, .td-reason { flex: 1; padding: 0 4rpx; }

.td-dish { font-weight: bold; color: #333; display: flex; align-items: center; }
.dish-dot { margin-right: 4rpx; font-size: 22rpx; }
.portion-num {
  display: inline-block; background: #E8B4B8; color: #fff;
  border-radius: 16rpx; padding: 4rpx 16rpx; font-size: 22rpx; font-weight: bold;
}
.td-excluded { color: #C4A5A5; font-size: 22rpx; }
.td-reason { color: #999; font-size: 20rpx; line-height: 1.4; }

/* ===== 房间制作状态卡片 ===== */
.pb-card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  margin-bottom: 16rpx; border-left: 8rpx solid #E8B4B8;
  box-shadow: 0 2rpx 12rpx rgba(255,107,157,0.08);
}
.pb-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.pb-room { font-size: 30rpx; font-weight: bold; }
.pb-mom { font-size: 24rpx; color: #999; }
.pb-badge { padding: 6rpx 18rpx; border-radius: 20rpx; color: #fff; font-size: 22rpx; }
.pb-dishes { font-size: 26rpx; color: #555; padding: 6rpx 0; }
.pb-excluded { font-size: 22rpx; color: #C4A5A5; padding: 6rpx 0; }
.pb-excluded-detail { font-size: 22rpx; color: #E8A0A0; padding: 4rpx 0; line-height: 1.4; }
.pb-cooking {
  background: #F9F5F2; padding: 10rpx 16rpx; border-radius: 8rpx;
  font-size: 24rpx; color: #E8B4B8; margin: 8rpx 0;
}

.pb-actions { margin-top: 14rpx; display: flex; gap: 12rpx; }
.pb-btn {
  flex:1; padding: 14rpx 0; background: #E8B4B8; color: #fff;
  border-radius: 25rpx; font-size: 24rpx; border: none; text-align: center;
}
.pb-btn.cooking { background: #D4BFA5; }
.pb-btn.done { background: #A29BFE; }

.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-hint { font-size: 24rpx; color: #ccc; margin-top: 10rpx; }
