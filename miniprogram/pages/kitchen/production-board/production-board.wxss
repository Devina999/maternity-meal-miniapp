.meal-tabs {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.meal-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  background: #fff;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.meal-tab.active {
  background: #4A90D9;
  color: #fff;
}

.date-label {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.stats-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 16rpx 0;
  font-size: 22rpx;
  color: #999;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-top: 4rpx;
}

.kanban-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 8rpx solid #4A90D9;
}

.kanban-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.room-num {
  font-size: 30rpx;
  font-weight: bold;
}

.mother-name {
  font-size: 24rpx;
  color: #666;
  margin-left: 12rpx;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  color: #fff;
  font-size: 22rpx;
}

.dish-list {
  margin-bottom: 10rpx;
}

.kanban-dish {
  padding: 6rpx 0;
  font-size: 26rpx;
}

.cooking-notes {
  background: #FFF8E1;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #E67E22;
  margin-bottom: 12rpx;
}

.marker {
  margin-right: 4rpx;
}

.status-actions {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
}

.status-btn {
  flex: 1;
  padding: 12rpx 0;
  background: #4A90D9;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: none;
  text-align: center;
}

.cooking-btn { background: #E67E22; }
.done-btn { background: #27AE60; }

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
}
