<wxs module="u">
var sName = {preparing:'制作中',completed:'制作完成',served:'上菜完成'};
var sColor = {preparing:'#FF9F43',completed:'#FF6B9D',served:'#A29BFE'};
module.exports = { n: sName, c: sColor };
</wxs>

<view class="pb-container">
  <!-- 日期 -->
  <view class="pb-date">📅 {{date}}（今日）</view>

  <!-- 餐别切换 -->
  <view class="pb-tabs">
    <view
      class="pb-tab {{activeMealType === item.value ? 'active' : ''}}"
      wx:for="{{mealTypeLabels}}" wx:key="value"
      data-type="{{item.value}}" bindtap="onMealTypeChange"
    >{{item.label}}</view>
  </view>

  <!-- 统计 -->
  <view class="pb-stats">
    <view class="pb-stat"><text class="pb-stat-num">{{stats.preparing}}</text>制作中</view>
    <view class="pb-stat"><text class="pb-stat-num">{{stats.completed}}</text>制作完成</view>
    <view class="pb-stat"><text class="pb-stat-num">{{stats.served}}</text>上菜完成</view>
  </view>

  <!-- 空状态：未发布菜单 -->
  <view class="empty-state" wx:if="{{!menu}}">
    <view class="empty-icon">📋</view>
    <view>暂无备餐数据</view>
    <view class="empty-hint">请先在每日菜单中发布今日餐单</view>
  </view>

  <!-- 菜品制作状态卡片 -->
  <view class="section" wx:if="{{dishes.length > 0}}">
    <view class="section-title">📊 菜品制作进度</view>
    <view class="dish-card" wx:for="{{dishes}}" wx:key="dish_id">
      <!-- 菜品名 + 状态标签 -->
      <view class="dish-card-top">
        <view class="dish-name">🍽️ {{item.dish_name}}</view>
        <view class="dish-badge" style="background:{{u.c(item.status)}}">
          {{u.n(item.status)}}
        </view>
      </view>

      <!-- 进度条 -->
      <view class="progress-wrap">
        <view class="progress-bar">
          <view class="progress-fill" style="width:{{item.progress}}%; background:{{u.c(item.status)}};"></view>
        </view>
        <text class="progress-text">{{item.progress}}%</text>
      </view>

      <!-- 操作按钮 -->
      <view class="dish-actions">
        <button
          wx:if="{{item.status === 'preparing' && canUpdateToCompleted}}"
          class="pb-btn completed"
          data-dish-id="{{item.dish_id}}"
          data-status="completed"
          bindtap="onStatusChange"
        >标记制作完成</button>

        <button
          wx:if="{{item.status === 'completed' && canUpdateToServed}}"
          class="pb-btn served"
          data-dish-id="{{item.dish_id}}"
          data-status="served"
          bindtap="onStatusChange"
        >标记上菜完成</button>

        <button
          wx:if="{{item.status === 'completed' && canUndo}}"
          class="pb-btn undo"
          data-dish-id="{{item.dish_id}}"
          data-status="preparing"
          bindtap="onStatusChange"
        >撤销制作完成</button>

        <button
          wx:if="{{item.status === 'served' && canUndo}}"
          class="pb-btn undo"
          data-dish-id="{{item.dish_id}}"
          data-status="completed"
          bindtap="onStatusChange"
        >撤销上菜完成</button>

        <view wx:if="{{item.status === 'preparing' && !canUpdateToCompleted}}" class="no-perm-hint">需后厨/主厨/管理员操作</view>
        <view wx:if="{{item.status === 'completed' && !canUpdateToServed && !canUndo}}" class="no-perm-hint">需护士/前厅经理/管理员操作</view>
        <view wx:if="{{item.status === 'served' && !canUndo}}" class="no-perm-hint">制作流程已完成</view>
      </view>
    </view>
  </view>
</view>
