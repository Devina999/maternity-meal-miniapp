<wxs module="utils">
var statusName = {pending:'待制作',cooking:'制作中',completed:'已完成',distributed:'已分餐'};
var statusColor = {pending:'#95A5A6',cooking:'#E67E22',completed:'#27AE60',distributed:'#4A90D9'};
module.exports = { statusName: statusName, statusColor: statusColor };
</wxs>

<view class="container">
  <!-- 餐别切换 -->
  <view class="meal-tabs">
    <view
      class="meal-tab {{activeMealType === item ? 'active' : ''}}"
      wx:for="{{mealTypes}}" wx:key="*this"
      data-type="{{item}}" bindtap="onMealTypeChange"
    >
      {{item === 'breakfast' ? '早餐' : item === 'lunch' ? '午餐' : item === 'dinner' ? '晚餐' : '加餐'}}
    </view>
  </view>

  <view class="date-label">{{date}}</view>

  <!-- 统计概览 -->
  <view class="stats-row">
    <view class="stat-item">待制作<text class="stat-num">{{getStats().pending}}</text></view>
    <view class="stat-item">制作中<text class="stat-num">{{getStats().cooking}}</text></view>
    <view class="stat-item">已完成<text class="stat-num">{{getStats().completed}}</text></view>
    <view class="stat-item">已分餐<text class="stat-num">{{getStats().distributed}}</text></view>
  </view>

  <!-- 看板卡片列表 -->
  <view wx:if="{{assignments.length > 0}}">
    <view class="kanban-card" wx:for="{{assignments}}" wx:key="_id">
      <view class="kanban-header">
        <view class="room-info">
          <text class="room-num">{{item.room_number || '未知'}}号房</text>
          <text class="mother-name" wx:if="{{item.mother_name}}">{{item.mother_name}}</text>
        </view>
        <view
          class="status-badge"
          style="background: {{utils.statusColor(item.production_status || 'pending')}}"
        >
          {{utils.statusName(item.production_status || 'pending')}}
        </view>
      </view>

      <!-- 菜品列表 -->
      <view class="dish-list">
        <view class="kanban-dish" wx:for="{{item.assigned_dish_ids}}" wx:key="*this" wx:for-item="did">
          <text>🍽️ {{getDishNameById(did)}}</text>
        </view>
      </view>

      <!-- 制作要求提示 -->
      <view class="cooking-notes" wx:if="{{item.cooking_notes}}">
        <text class="marker">🔶</text> {{item.cooking_notes}}
      </view>

      <!-- 状态更新按钮（仅编辑权限） -->
      <view class="status-actions" wx:if="{{canUpdateStatus && (item.production_status || 'pending') !== 'distributed'}}">
        <button
          class="btn-sm status-btn"
          wx:if="{{(item.production_status || 'pending') === 'pending'}}"
          data-id="{{item._id}}" data-status="cooking"
          bindtap="onStatusChange"
        >开始制作</button>
        <button
          class="btn-sm status-btn cooking-btn"
          wx:if="{{(item.production_status || 'pending') === 'cooking'}}"
          data-id="{{item._id}}" data-status="completed"
          bindtap="onStatusChange"
        >标记完成</button>
        <button
          class="btn-sm status-btn done-btn"
          wx:if="{{(item.production_status || 'pending') === 'completed'}}"
          data-id="{{item._id}}" data-status="distributed"
          bindtap="onStatusChange"
        >标记已分餐</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{assignments.length === 0}}">
    <view>暂无备餐数据</view>
    <view class="empty-hint">请先发布今日餐单</view>
  </view>
</view>
