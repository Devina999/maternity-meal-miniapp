<wxs module="u">
var sName = {pending:'待制作',cooking:'制作中',completed:'已完成',distributed:'已分餐'};
var sColor = {pending:'#bbb',cooking:'#FF9F43',completed:'#FF6B9D',distributed:'#A29BFE'};
module.exports = { n: sName, c: sColor };
</wxs>

<view class="pb-container">
  <!-- 日期 -->
  <view class="pb-date">📅 {{date}}</view>

  <!-- 餐别切换 -->
  <view class="pb-tabs">
    <view
      class="pb-tab {{activeMealType === item.value ? 'active' : ''}}"
      wx:for="{{mealTypeLabels}}" wx:key="value"
      data-type="{{item.value}}" bindtap="onMealTypeChange"
    >{{item.label}}</view>
  </view>

  <!-- 统计 -->
  <view class="pb-stats">
    <view class="pb-stat"><text class="pb-stat-num">{{stats.pending}}</text>待制作</view>
    <view class="pb-stat"><text class="pb-stat-num">{{stats.cooking}}</text>制作中</view>
    <view class="pb-stat"><text class="pb-stat-num">{{stats.completed}}</text>已完成</view>
    <view class="pb-stat"><text class="pb-stat-num">{{stats.distributed}}</text>已分餐</view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{assignments.length === 0}}">
    <view class="empty-icon">📋</view>
    <view>暂无备餐数据</view>
    <view class="empty-hint">请先发布今日餐单</view>
  </view>

  <!-- ===== 菜品维度汇总表 ===== -->
  <view class="section" wx:if="{{dishTable.length > 0}}">
    <view class="section-title">📊 备餐份数总览</view>
    <view class="dish-summary-table">
      <!-- 表头 -->
      <view class="table-header">
        <view class="th-dish">菜品</view>
        <view class="th-portion">准备份数</view>
        <view class="th-excluded">排除房间</view>
        <view class="th-reason">冲突原因</view>
      </view>
      <!-- 表行 -->
      <view class="table-row" wx:for="{{dishTable}}" wx:key="dish_id">
        <view class="td-dish">
          <text class="dish-dot">🍽️</text> {{item.dish_name}}
        </view>
        <view class="td-portion">
          <text class="portion-num">{{item.portion}}</text>
        </view>
        <view class="td-excluded">{{item.excludedRooms}}</view>
        <view class="td-reason">{{item.exclusionDetails || '—'}}</view>
      </view>
    </view>
  </view>

  <!-- ===== 房间制作状态卡片 ===== -->
  <view class="section" wx:if="{{assignments.length > 0}}">
    <view class="section-title">📋 房间制作进度</view>
    <view class="pb-card" wx:for="{{assignments}}" wx:key="_id">
      <view class="pb-card-top">
        <view>
          <text class="pb-room">{{item.room_number || '?'}}号房</text>
          <text class="pb-mom" wx:if="{{item.mother_name}}"> · {{item.mother_name}}</text>
        </view>
        <view class="pb-badge" style="background:{{u.c(item.production_status || 'pending')}}">
          {{u.n(item.production_status || 'pending')}}
        </view>
      </view>
      <view class="pb-dishes">🍽️ {{item.dishNames}}</view>
      <view class="pb-excluded" wx:if="{{item.excludedNames}}">✗ 已排除：{{item.excludedNames}}</view>
      <view class="pb-excluded-detail" wx:if="{{item.exclusionDetails}}">⚠️ {{item.exclusionDetails}}</view>
      <view class="pb-cooking" wx:if="{{item.cooking_notes}}">🔶 {{item.cooking_notes}}</view>

      <view class="pb-actions" wx:if="{{canUpdateStatus && (item.production_status || 'pending') !== 'distributed'}}">
        <button class="pb-btn" wx:if="{{(item.production_status || 'pending') === 'pending'}}" data-id="{{item._id}}" data-status="cooking" bindtap="onStatusChange">开始制作</button>
        <button class="pb-btn cooking" wx:if="{{(item.production_status || 'pending') === 'cooking'}}" data-id="{{item._id}}" data-status="completed" bindtap="onStatusChange">标记完成</button>
        <button class="pb-btn done" wx:if="{{(item.production_status || 'pending') === 'completed'}}" data-id="{{item._id}}" data-status="distributed" bindtap="onStatusChange">标记已分餐</button>
      </view>
    </view>
  </view>
</view>
