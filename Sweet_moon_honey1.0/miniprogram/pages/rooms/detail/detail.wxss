.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-label {
  color: #999;
  font-size: 26rpx;
}

.detail-value {
  color: #333;
  font-size: 26rpx;
}

.detail-notes {
  padding: 16rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.restriction-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.restriction-item:last-child {
  border-bottom: none;
}

.tag-row {
  margin-bottom: 8rpx;
}

.custom-note {
  font-size: 26rpx;
  color: #666;
  margin-top: 6rpx;
}

.cooking-note {
  font-size: 26rpx;
  color: #D4BFA5;
  margin-top: 6rpx;
}

.marker {
  margin-right: 4rpx;
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.action-bar button {
  flex: 1;
  font-size: 26rpx;
}

.empty-text {
  color: #ccc;
  font-size: 26rpx;
  text-align: center;
  padding: 20rpx 0;
}
